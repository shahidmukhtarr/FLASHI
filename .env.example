# Supabase settings for backend persistence
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Scheduler settings
# How often to auto-scrape (in minutes). Default: 240 (4 hours)
SCRAPER_INTERVAL_MINUTES=240
# Comma-separated queries to scrape on schedule
SCRAPER_QUERIES=iPhone 15,Samsung Galaxy S24,MacBook Air,PlayStation 5,AirPods Pro,Smartwatch,Power bank,Gaming laptop,Wireless headphones,Canon DSLR
# Run an immediate scrape when the server starts (true/false)
# SCRAPER_RUN_ON_START=true
# Seed categories every N scheduler runs (default: 5)
# SCRAPER_SEED_CATEGORIES_EVERY=5
